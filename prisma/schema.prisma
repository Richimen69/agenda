// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. USUARIOS
model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String   @default("123456") // NUEVO: Contraseña encriptada
  whatsappPhone String
  role          Role     @default(USER) // NUEVO: Rol del usuario
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  createdTickets          Ticket[]               @relation("CreatedTickets")
  assignedTickets         Ticket[]               @relation("AssignedTickets")
  eventsCreated           Event[]                @relation("EventCreator")
  eventsAttending         Event[]                @relation("EventAttendees")
  reminders               Reminder[]
  auditLogs               AuditLog[]
  comments                Comment[]
  subtasks                Subtask[]
  shortLinks              ShortLink[]
  proyectosCreados        Proyecto[]             @relation("ProyectoCreator")
  participacionesProyecto ProyectoParticipante[]
  accionesAsignadas       Accion[]               @relation("AccionOwner")
  kpiRegistros            KpiRegistro[]
  comentariosProyecto     ProyectoComment[]
  areaId                  String?
  area                    Area?                  @relation("UsuarioArea", fields: [areaId], references: [id], onDelete: SetNull)
  advisorSessions    LiveSession[] @relation("AdvisorSessions")
  technicianSessions LiveSession[] @relation("TechnicianSessions")
}

// 2. TICKETS / PROYECTOS
model Ticket {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      Status   @default(NUEVO) // Estado inicial cambiado
  priority    Priority @default(MEDIA)
  creatorId   String
  creator     User     @relation("CreatedTickets", fields: [creatorId], references: [id])

  assignees User[] @relation("AssignedTickets")

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  events    Event[]
  reminders Reminder[]
  auditLogs AuditLog[]
  comments  Comment[]
  subtasks  Subtask[]
}

// 3. NUEVO: AGENDA COLABORATIVA
model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  scheduledAt DateTime // Fecha y hora del evento

  // Quién lo creó
  creatorId String
  creator   User   @relation("EventCreator", fields: [creatorId], references: [id])

  // Opcional: ¿Está vinculado a un proyecto/ticket?
  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  // Invitados al evento (Relación implícita muchos-a-muchos de Prisma)
  attendees User[] @relation("EventAttendees")

  reminders Reminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4. RECORDATORIOS (Nuestra Cola Universal para WhatsApp)
model Reminder {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketId   String?
  ticket     Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  eventId    String?
  event      Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  proyectoId String?
  proyecto   Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  accionId       String?
  accion         Accion?        @relation(fields: [accionId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime // Cuándo debe enviarse el WhatsApp
  messagePayload String         @db.Text // El texto exacto a enviar
  status         ReminderStatus @default(PENDING)
  retryCount     Int            @default(0)
  errorLog       String?        @db.Text
  sentAt         DateTime?
  createdAt      DateTime       @default(now())

  @@index([status, scheduledAt])
}

model Comment {
  id   String @id @default(uuid())
  text String @db.Text

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  proyectoId String?
  proyecto   Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// 5. BITÁCORA
model AuditLog {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   Json
  createdAt DateTime @default(now())
}

model Subtask {
  id     String  @id @default(uuid())
  title  String
  isDone Boolean @default(false)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model ShortLink {
  id          String @id @default(uuid()) // Ajustado a UUID por consistencia
  originalUrl String @db.Text
  shortCode   String @unique
  clicks      Int    @default(0)

  userId String // Ajustado a String para poder relacionarse con User.id
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shortCode])
}

model Proyecto {
  id            String         @id @default(uuid())
  titulo        String
  descripcion   String?        @db.Text
  estado        StatusProyecto @default(NUEVO)
  fechaObjetivo DateTime

  // CACHÉ DE KPIS (Roll-ups para Dashboard ultrarrápido)
  avanceGlobal Float         @default(0)
  salud        SaludProyecto @default(VERDE)

  creatorId String
  creator   User   @relation("ProyectoCreator", fields: [creatorId], references: [id])

  // Relaciones
  participantes ProyectoParticipante[]
  acciones      Accion[]
  reminders     Reminder[]
  comentarios   ProyectoComment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
}

model ProyectoParticipante {
  id String @id @default(uuid())

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tipoRol RolParticipante // OWNER, SOPORTE, OBSERVER

  areaId String
  area   Area   @relation(fields: [areaId], references: [id])

  createdAt DateTime @default(now())

  // Un usuario no puede tener dos roles en el mismo proyecto
  @@unique([proyectoId, userId])
}

model Accion {
  id     String @id @default(uuid())
  titulo String

  // Matemáticas de Impacto
  peso   Float @default(1.0)
  avance Float @default(0) // CACHÉ de la acción en sí misma

  fechaInicio DateTime
  fechaFin    DateTime

  // Responsable directo (opcional si es una tarea agrupadora)
  ownerId String?
  owner   User?   @relation("AccionOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  // --- MAGIA: ÁRBOL JERÁRQUICO INFINITO ---
  parentId String?
  parent   Accion?  @relation("AccionHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Accion[] @relation("AccionHierarchy")

  kpis      Kpi[]
  reminders Reminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kpi {
  id     String  @id @default(uuid())
  nombre String // Ej. 'Prospectos', 'Presupuesto gastado'
  unidad String // Ej. 'clientes', 'MXN', '%'
  meta   Float
  tipo   TipoKpi // ACUMULABLE o ESTADO

  valorActual Float @default(0)

  accionId String
  accion   Accion @relation(fields: [accionId], references: [id], onDelete: Cascade)

  registros KpiRegistro[]
}

model KpiRegistro {
  id    String  @id @default(uuid())
  valor Float
  nota  String? @db.Text

  kpiId String
  kpi   Kpi    @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// Bitácora clonada para aislarla 100% de los Tickets operativos
model ProyectoComment {
  id   String @id @default(uuid())
  text String @db.Text

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Area {
  id            String                 @id @default(uuid())
  nombre        String                 @unique
  parentId      String?
  parent        Area?                  @relation("AreaJerarquia", fields: [parentId], references: [id], onDelete: SetNull)
  hijos         Area[]                 @relation("AreaJerarquia")
  participantes ProyectoParticipante[]
  usuarios      User[]                 @relation("UsuarioArea")
}

// =========================================================
// MÓDULO DE TRANSMISIONES EN VIVO (TOYOTA LIVE)
// =========================================================

model LiveSession {
  id             String        @id @default(uuid())
  roomName       String        // Ej: Placas o No. Orden
  customerName   String
  customerPhone  String?
  vehicleModel   String?

  // Relación con el Asesor de Servicio (User creador)
  advisorId      String?
  advisor        User?         @relation("AdvisorSessions", fields: [advisorId], references: [id], onDelete: SetNull)

  // Relación con el Técnico asignado (User emisor)
  technicianId   String?
  technician     User?         @relation("TechnicianSessions", fields: [technicianId], references: [id], onDelete: SetNull)

  status         SessionStatus @default(WAITING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  recordings     LiveRecording[]
}

model LiveRecording {
  id          String       @id @default(uuid())
  sessionId   String
  session     LiveSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileUrl     String       @db.Text
  fileSize    BigInt?
  createdAt   DateTime     @default(now())
}

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum Status {
  NUEVO
  EN_PROGRESO
  REVISION
  COMPLETADO
}

enum ReminderStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum Role {
  ADMIN
  USER
}

enum Priority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum StatusProyecto {
  NUEVO
  EN_PROGRESO
  REVISION
  COMPLETADO
}

enum SaludProyecto {
  VERDE
  AMARILLO
  ROJO
}

enum RolParticipante {
  OWNER
  SOPORTE
  OBSERVER
}

enum TipoKpi {
  ACUMULABLE // Ej: Ventas del mes (se suman los registros)
  ESTADO // Ej: Porcentaje de instalación (se toma el último registro)
}
