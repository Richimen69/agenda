// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. USUARIOS
model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String   @default("123456") // NUEVO: Contraseña encriptada
  whatsappPhone String
  role          Role     @default(USER) // NUEVO: Rol del usuario
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  createdTickets     Ticket[]         @relation("CreatedTickets")
  assignedTickets    Ticket[]         @relation("AssignedTickets")
  eventsCreated      Event[]          @relation("EventCreator")
  eventsAttending    Event[]          @relation("EventAttendees")
  reminders          Reminder[]
  auditLogs          AuditLog[]
  comments           Comment[]
  subtasks           Subtask[]
  shortLinks         ShortLink[]
  createdProjects    Project[]        @relation("ProjectCreator")
  projectMemberships ProjectMember[]
  assignedActions    ProjectAction[]  @relation("ActionOwner")
  kpiRecords         KpiRecord[]
  projectComments    ProjectComment[]
  areaId             String?
  area               Area?            @relation("UserArea", fields: [areaId], references: [id], onDelete: SetNull)
  advisorSessions    LiveSession[]    @relation("AdvisorSessions")
  technicianSessions LiveSession[]    @relation("TechnicianSessions")
}

// 2. TICKETS / PROYECTOS
model Ticket {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      Status   @default(NUEVO) // Estado inicial cambiado
  priority    Priority @default(MEDIA)
  creatorId   String
  creator     User     @relation("CreatedTickets", fields: [creatorId], references: [id])

  assignees User[] @relation("AssignedTickets")

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  events    Event[]
  reminders Reminder[]
  auditLogs AuditLog[]
  comments  Comment[]
  subtasks  Subtask[]
}

// 3. NUEVO: AGENDA COLABORATIVA
model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  scheduledAt DateTime // Fecha y hora del evento

  // Quién lo creó
  creatorId String
  creator   User   @relation("EventCreator", fields: [creatorId], references: [id])

  // Opcional: ¿Está vinculado a un proyecto/ticket?
  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  // Invitados al evento (Relación implícita muchos-a-muchos de Prisma)
  attendees User[] @relation("EventAttendees")

  reminders Reminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4. RECORDATORIOS (Nuestra Cola Universal para WhatsApp)
model Reminder {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketId       String?
  ticket         Ticket?        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  eventId        String?
  event          Event?         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actionId       String?
  action         ProjectAction? @relation(fields: [actionId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime // Cuándo debe enviarse el WhatsApp
  messagePayload String         @db.Text // El texto exacto a enviar
  status         ReminderStatus @default(PENDING)
  retryCount     Int            @default(0)
  errorLog       String?        @db.Text
  sentAt         DateTime?
  createdAt      DateTime       @default(now())

  @@index([status, scheduledAt])
}

model Comment {
  id       String  @id @default(uuid())
  text     String  @db.Text
  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// 5. BITÁCORA
model AuditLog {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   Json
  createdAt DateTime @default(now())
}

model Subtask {
  id     String  @id @default(uuid())
  title  String
  isDone Boolean @default(false)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model ShortLink {
  id          String @id @default(uuid()) // Ajustado a UUID por consistencia
  originalUrl String @db.Text
  shortCode   String @unique
  clicks      Int    @default(0)

  userId String // Ajustado a String para poder relacionarse con User.id
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shortCode])
}

model Project {
  id             String        @id @default(uuid())
  title          String
  description    String?       @db.Text
  status         ProjectStatus @default(NEW)
  targetDate     DateTime
  globalProgress Float         @default(0)
  health         ProjectHealth @default(GREEN)

  creatorId String
  creator   User   @relation("ProjectCreator", fields: [creatorId], references: [id])

  // Relations
  members         ProjectMember[]
  actions         ProjectAction[]
  reminders       Reminder[]
  projectComments ProjectComment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
}

model ProjectMember {
  id        String     @id @default(uuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleType  MemberRole // OWNER, SUPPORT, OBSERVER
  areaId    String
  area      Area       @relation(fields: [areaId], references: [id])

  businessRole String?
  createdAt    DateTime @default(now())

  @@unique([projectId, userId])
}

model ProjectAction {
  id        String   @id @default(uuid())
  title     String
  weight    Float    @default(1.0)
  progress  Float    @default(0)
  startDate DateTime
  endDate   DateTime

  ownerId   String?
  owner     User?   @relation("ActionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Infinite Hierarchical Tree
  parentId String?
  parent   ProjectAction?  @relation("ActionHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children ProjectAction[] @relation("ActionHierarchy")

  kpis      Kpi[]
  reminders Reminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Kpi {
  id           String  @id @default(uuid())
  name         String
  unit         String
  target       Float
  type         KpiType
  currentValue Float   @default(0)

  actionId String
  action   ProjectAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  records  KpiRecord[]
}

model KpiRecord {
  id     String  @id @default(uuid())
  value  Float
  note   String? @db.Text
  kpiId  String
  kpi    Kpi     @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  userId String
  user   User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model ProjectComment {
  id        String  @id @default(uuid())
  text      String  @db.Text
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Area {
  id       String          @id @default(uuid())
  name     String          @unique
  parentId String?
  parent   Area?           @relation("AreaHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Area[]          @relation("AreaHierarchy")
  members  ProjectMember[]
  users    User[]          @relation("UserArea")
}

// =========================================================
// MÓDULO DE TRANSMISIONES EN VIVO (TOYOTA LIVE)
// =========================================================

model LiveSession {
  id            String  @id @default(uuid())
  roomName      String
  customerName  String
  customerPhone String?
  vehicleModel  String?

  // RELACIÓN CON EL TIPO DE SERVICIO SELECCIONADO
  serviceTypeId String?
  serviceType   ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)

  // RELACIÓN CON LA ETAPA ACTUAL (ID de la tabla ServiceStage)
  currentStageId String?
  currentStage   ServiceStage? @relation("CurrentStage", fields: [currentStageId], references: [id], onDelete: SetNull)

  advisorId    String?
  advisor      User?           @relation("AdvisorSessions", fields: [advisorId], references: [id], onDelete: SetNull)
  technicianId String?
  technician   User?           @relation("TechnicianSessions", fields: [technicianId], references: [id], onDelete: SetNull)
  status       SessionStatus   @default(WAITING)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  recordings   LiveRecording[]
}

model LiveRecording {
  id        String      @id @default(uuid())
  sessionId String
  session   LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileUrl   String      @db.Text
  fileSize  BigInt?
  createdAt DateTime    @default(now())
}

model ServiceType {
  id          String   @id @default(uuid())
  name        String   @unique // Ej. 'Mantenimiento Express 60k', 'Diagnóstico Eléctrico'
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages   ServiceStage[] // Relación con sus etapas configuradas
  sessions LiveSession[] // Sesiones asociadas a este tipo de servicio
}

model ServiceStage {
  id    String @id @default(uuid())
  name  String // Ej. 'Recepción', 'Alineación', 'Lavado', 'Listo'
  order Int // Secuencia numérica (1, 2, 3...) de la etapa en este servicio

  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  // Sesiones que se encuentran actualmente en esta etapa específica
  currentSessions LiveSession[] @relation("CurrentStage")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Evita que existan dos etapas con el mismo orden en el mismo tipo de servicio
  @@unique([serviceTypeId, order])
}

enum SessionStatus {
  WAITING
  ACTIVE
  FINISHED
}

enum Status {
  NUEVO
  EN_PROGRESO
  REVISION
  COMPLETADO
}

enum ReminderStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum Role {
  ADMIN
  USER
}

enum Priority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum ProjectStatus {
  NEW         @map("NUEVO")
  IN_PROGRESS @map("EN_PROGRESO")
  REVIEW      @map("REVISION")
  COMPLETED   @map("COMPLETADO")
}

enum ProjectHealth {
  GREEN  @map("VERDE")
  YELLOW @map("AMARILLO")
  RED    @map("ROJO")
}

enum MemberRole {
  OWNER    @map("OWNER")
  SUPPORT  @map("SOPORTE")
  OBSERVER @map("OBSERVER")
}

enum KpiType {
  ACCUMULABLE @map("ACUMULABLE")
  STATUS      @map("ESTADO")
}
